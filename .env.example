NODE_ENV=development
DATABASE_URL=postgres://trader:changeme@localhost:5432/prediction_arb

# Kalshi (execution)
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY_PEM=   # path to .pem or inline PEM
KALSHI_PRIVATE_KEY_PATH=  # or path to .pem file (e.g. ./kalshi_key.pem)
# KALSHI_DEMO=false       # set false for prod; true needs demo.kalshi.co credentials

# Polymarket (execution)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_PROXY=         # Gnosis Safe proxy address

# Execution: set true to simulate without placing orders
DRY_RUN=true
